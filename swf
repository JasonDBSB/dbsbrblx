local function makeTab(name, order)
    local btn = Instance.new("TextButton", tabBar)
    btn.Size = UDim2.new(0, 76, 1, 0)
    btn.BackgroundColor3 = Color3.fromRGB(8, 11, 18)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(120, 140, 180)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.LayoutOrder = order

    local scroll = Instance.new("ScrollingFrame", contentArea)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = BLUE2
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.Visible = false

    local layout = Instance.new("UIListLayout", scroll)
    layout.Padding = UDim.new(0, 3)
    local pad = Instance.new("UIPadding", scroll)
    pad.PaddingLeft = UDim.new(0, 6)
    pad.PaddingTop = UDim.new(0, 6)
    pad.PaddingRight = UDim.new(0, 6)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
    end)

    local tab = {btn=btn, scroll=scroll}
    tabs[name] = tab

    btn.MouseButton1Click:Connect(function()
        if activeTab then
            activeTab.btn.BackgroundColor3 = Color3.fromRGB(8, 11, 18)
            activeTab.btn.TextColor3 = Color3.fromRGB(120, 140, 180)
            activeTab.scroll.Visible = false
        end
        activeTab = tab
        btn.BackgroundColor3 = DARK2
        btn.TextColor3 = BLUE
        scroll.Visible = true
    end)

    return tab
end

