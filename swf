-- ── Slider builder ────────────────────────
local function makeSlider(scroll, key, label, min, max, step)
    local val = currentTune and currentTune[key] or stockValues[key] or (min+max)/2
    step = step or 1

    local row = Instance.new("Frame", scroll)
    row.Size = UDim2.new(1, -4, 0, 34)
    row.BackgroundColor3 = DARK3
    row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 3)

    local nameLbl = Instance.new("TextLabel", row)
    nameLbl.Size = UDim2.new(0.36, 0, 1, 0)
    nameLbl.Position = UDim2.new(0, 6, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = label
    nameLbl.TextColor3 = TEXT
    nameLbl.TextSize = 11
    nameLbl.Font = Enum.Font.Gotham
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.TextWrapped = true

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0.38, 0, 0, 6)
    track.Position = UDim2.new(0.36, 4, 0.5, -3)
    track.BackgroundColor3 = BLUE3
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 3)

    local pct = math.clamp((val-min)/(max-min), 0, 1)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = BLUE2
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(pct, -6, 0.5, -6)
    knob.BackgroundColor3 = BLUE
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(0.5, 0)

    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0.14, 0, 1, 0)
    valLbl.Position = UDim2.new(0.76, 2, 0, 0)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = string.format(step<1 and "%.2f" or "%.0f", val)
    valLbl.TextColor3 = BLUE
    valLbl.TextSize = 11
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextXAlignment = Enum.TextXAlignment.Left

    local setBtn = Instance.new("TextButton", row)
    setBtn.Size = UDim2.new(0, 38, 0, 22)
    setBtn.Position = UDim2.new(1, -42, 0.5, -11)
    setBtn.BackgroundColor3 = BLUE3
    setBtn.Text = "SET"
    setBtn.TextColor3 = BLUE
    setBtn.TextSize = 10
    setBtn.Font = Enum.Font.GothamBold
    setBtn.BorderSizePixel = 0
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 3)

    local currentVal = val
    local sliding = false

    local function update(x)
        local p2 = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local v = min + (max-min)*p2
        v = math.floor(v/step + 0.5)*step
        v = math.clamp(v, min, max)
        currentVal = v
        fill.Size = UDim2.new(p2, 0, 1, 0)
        knob.Position = UDim2.new(p2, -6, 0.5, -6)
        valLbl.Text = string.format(step<1 and "%.2f" or "%.0f", v)
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true update(i.Position.X) end
    end)
    knob.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true end
    end)
    UIS.InputChanged:Connect(function(i)
        if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then update(i.Position.X) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
    end)
    setBtn.MouseButton1Click:Connect(function()
        applyValue(key, currentVal)
        setBtn.BackgroundColor3 = Color3.fromRGB(20, 60, 20)
        task.delay(0.3, function() setBtn.BackgroundColor3 = BLUE3 end)
    end)

    tunerRows[key] = {currentVal=currentVal}
    return row
end

